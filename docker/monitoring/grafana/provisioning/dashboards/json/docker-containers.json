{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_project, container_label_com_docker_compose_service, name) (rate(container_cpu_user_total[5m]) + rate(container_cpu_system_total[5m]))",
          "legendFormat": "{{ container_label_com_docker_compose_project }}/{{ container_label_com_docker_compose_service }} ({{ name }})",
          "refId": "A"
        }
      ],
      "title": "CPU by container",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "container_memory_usage",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "title": "Memory by container",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (name) (rate(container_blkio_read_total[5m]))",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "title": "Disk read",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (name) (rate(container_blkio_write_total[5m]))",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "title": "Disk write",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docker", "duty"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
