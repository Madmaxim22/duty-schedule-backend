# Скопируйте в .env на NAS: cp .env.example .env

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
GF_SERVER_ROOT_URL=https://grafana.duty-w.ru
GF_SERVER_DOMAIN=grafana.duty-w.ru

# LAN: Grafana на всех интерфейсах NAS (http://192.168.x.x:3000). Не пробрасывать :3000 на роутере.
# Только localhost: GRAFANA_HOST_BIND=127.0.0.1
GRAFANA_HOST_BIND=0.0.0.0
GRAFANA_PORT=3000

# Если по IP редиректит на grafana.duty-w.ru и ломается — для чисто LAN-доступа:
# GF_SERVER_ROOT_URL=http://192.168.3.85:3000

# DSN PostgreSQL Duty (сеть duty-internal, хост db)
POSTGRES_EXPORTER_DSN=postgresql://duty:duty@db:5432/duty_schedule?sslmode=disable

# Каталог metadata контейнеров (опционально; на containerd snapshotter часто нет — dockerprom работает через cgroup)
# DOCKER_CONTAINERS_DIR=/srv/dev-disk-by-uuid-7b779ac5-3f1c-4c5d-98bc-5ed97247f35c/docker/containers
