DATABASE_URL=postgresql://duty:duty@localhost:5432/duty_schedule
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_DAYS=7
# CORS_ORIGIN=http://localhost:5173
ADMIN_EMAIL=admin@duty.local
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Администратор
# HTTP (LAN / dev без push на телефоне): COOKIE_SECURE=false
# COOKIE_SECURE=false
# CORS_ORIGIN=http://192.168.1.105:5173

# HTTPS локально (npm run dev:https:host во frontend) или production:
COOKIE_SECURE=true
CORS_ORIGIN=https://192.168.1.105:5173
# CORS_ORIGIN=https://duty-w.ru
UPLOAD_DIR=uploads
# Макс. размер исходника до сжатия (JPEG/PNG/WebP), байты; 15 МБ
MAX_AVATAR_SIZE=15728640
# Чат: вложения-изображения (JPEG/PNG/WebP/GIF)
MAX_CHAT_ATTACHMENT_SIZE=8388608
MAX_CHAT_ATTACHMENTS_PER_MESSAGE=10
CHAT_ATTACHMENT_ORPHAN_TTL_MS=3600000

# Web Push (оповещение админа о новых заявках): npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@duty-w.ru

# Версия приложения (опционально; иначе из package.json)
# APP_VERSION=1.2.0
# APP_RELEASE_ID=1.2.0
# ACHIEVEMENT_REVEAL_LAST_DAYS=5
# ACHIEVEMENT_REVEAL_GRACE_DAYS=7