# Пример .env для NAS с HTTPS (duty-w.ru + NPM).
# Скопируйте в .env на сервере и задайте секреты.

NODE_ENV=production
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_DAYS=7

CORS_ORIGIN=https://duty-w.ru
COOKIE_SECURE=true

ADMIN_EMAIL=admin@duty.local
ADMIN_PASSWORD=change-me-before-first-login
ADMIN_FULL_NAME=Администратор

UPLOAD_DIR=uploads
MAX_AVATAR_SIZE=15728640

# Web Push (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@duty-w.ru
