generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum UserStatus {
  pending
  approved
  rejected
}

enum DutySection {
  A
  B
}

enum DutyChangeType {
  assigned
  removed
  replaced
}

enum DutyChangeSource {
  import
  manual
}

enum NotificationType {
  photo_like
  duty_change
  user_registration
  support_message
  chat_message
}

enum ChatRoomType {
  direct
  group
}

enum SupportThreadStatus {
  open
  closed
}

enum AuthEventType {
  login
  register
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  fullName        String     @map("full_name")
  role            UserRole   @default(user)
  status          UserStatus @default(pending)
  avatarUrl       String?    @map("avatar_url")
  currentPhotoId  String?    @unique @map("current_photo_id")
  avatarFocusX    Int        @default(50) @map("avatar_focus_x")
  avatarFocusY    Int        @default(50) @map("avatar_focus_y")
  createdAt       DateTime   @default(now()) @map("created_at")
  lastActiveAt    DateTime?  @map("last_active_at")

  currentPhoto            UserPhoto?             @relation("CurrentPhoto", fields: [currentPhotoId], references: [id], onDelete: SetNull)
  photos                  UserPhoto[]            @relation("UserPhotos")
  assignments             DutyAssignment[]       @relation("AssignedUser")
  assignmentsMade         DutyAssignment[]       @relation("AssignedBy")
  refreshTokens           RefreshToken[]
  absences                UserAbsence[]
  dutyChangesAsPrevious   DutyAssignmentChange[] @relation("PreviousUser")
  dutyChangesAsNew        DutyAssignmentChange[] @relation("NewUser")
  photoLikesGiven         PhotoLike[]            @relation("PhotoLikesGiven")
  pushSubscriptions       PushSubscription[]
  notifications           Notification[]         @relation("NotificationRecipient")
  notificationsActed      Notification[]         @relation("NotificationActor")
  supportThreadsAuthored    SupportThread[]        @relation("SupportThreadAuthor")
  supportMessagesAuthored   SupportMessage[]       @relation("SupportMessageAuthor")
  chatRoomsCreated          ChatRoom[]             @relation("ChatRoomCreator")
  chatMemberships           ChatMember[]
  chatMessagesAuthored      ChatMessage[]             @relation("ChatMessageAuthor")
  chatMessagesDeleted       ChatMessage[]             @relation("ChatMessageDeletedBy")
  chatDeliveries            ChatMessageDelivery[]
  chatMessageReactions      ChatMessageReaction[]
  chatMessageHides          ChatMessageUserHide[]
  chatAttachmentsUploaded   ChatMessageAttachment[]   @relation("ChatAttachmentUploader")
  authEvents                AuthEvent[]

  @@index([lastActiveAt])
  @@map("users")
}

model AuthEvent {
  id        String        @id @default(uuid())
  type      AuthEventType
  userId    String?       @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("auth_events")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model UserPhoto {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  url       String
  isCurrent Boolean  @default(false) @map("is_current")
  focusX    Int      @default(50) @map("focus_x")
  focusY    Int      @default(50) @map("focus_y")
  createdAt DateTime @default(now()) @map("created_at")

  user         User        @relation("UserPhotos", fields: [userId], references: [id], onDelete: Cascade)
  currentUser  User?       @relation("CurrentPhoto")
  likes        PhotoLike[]

  @@index([userId, isCurrent])
  @@index([userId, createdAt])
  @@map("user_photos")
}

model PhotoLike {
  id         String    @id @default(uuid())
  likerId    String    @map("liker_id")
  photoId    String    @map("photo_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  notifiedAt DateTime? @map("notified_at")

  liker        User          @relation("PhotoLikesGiven", fields: [likerId], references: [id], onDelete: Cascade)
  photo        UserPhoto     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  notification Notification?

  @@unique([likerId, photoId])
  @@index([photoId, notifiedAt])
  @@map("photo_likes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model DutyAssignment {
  id         String      @id @default(uuid())
  dutyDate   DateTime    @map("duty_date") @db.Date
  section    DutySection
  office     String
  userId     String?     @map("user_id")
  assignedBy String?     @map("assigned_by")
  createdAt  DateTime    @default(now()) @map("created_at")

  user     User? @relation("AssignedUser", fields: [userId], references: [id], onDelete: SetNull)
  assigner User? @relation("AssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@unique([dutyDate, section, office])
  @@index([dutyDate])
  @@index([userId, dutyDate])
  @@map("duty_assignments")
}

model UserAbsence {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  absenceDate DateTime @map("absence_date") @db.Date
  absenceType String   @map("absence_type")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, absenceDate])
  @@index([absenceDate])
  @@map("user_absences")
}

model DutyAssignmentChange {
  id             String           @id @default(uuid())
  dutyDate       DateTime         @map("duty_date") @db.Date
  section        DutySection
  office         String
  previousUserId String?          @map("previous_user_id")
  newUserId      String?          @map("new_user_id")
  changeType     DutyChangeType   @map("change_type")
  source         DutyChangeSource
  batchId        String           @map("batch_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  notifiedAt     DateTime?        @map("notified_at")

  previousUser  User?          @relation("PreviousUser", fields: [previousUserId], references: [id], onDelete: SetNull)
  newUser       User?          @relation("NewUser", fields: [newUserId], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([notifiedAt, createdAt])
  @@index([createdAt])
  @@map("duty_assignment_changes")
}

model Notification {
  id                     String           @id @default(uuid())
  userId                 String           @map("user_id")
  type                   NotificationType
  body                   String
  readAt                 DateTime?        @map("read_at")
  createdAt              DateTime         @default(now()) @map("created_at")
  actorUserId            String?          @map("actor_user_id")
  photoLikeId            String?          @unique @map("photo_like_id")
  dutyAssignmentChangeId String?          @map("duty_assignment_change_id")
  payload                Json?

  user                   User                  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor                  User?                 @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  photoLike              PhotoLike?            @relation(fields: [photoLikeId], references: [id], onDelete: Cascade)
  dutyAssignmentChange   DutyAssignmentChange? @relation(fields: [dutyAssignmentChangeId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([dutyAssignmentChangeId])
  @@map("notifications")
}

model SupportThread {
  id        String              @id @default(uuid())
  authorId  String              @map("author_id")
  status    SupportThreadStatus @default(open)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  author   User             @relation("SupportThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([authorId, updatedAt])
  @@index([status, updatedAt])
  @@map("support_threads")
}

model SupportMessage {
  id        String   @id @default(uuid())
  threadId  String   @map("thread_id")
  authorId  String   @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  thread SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User          @relation("SupportMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("support_messages")
}

model ChatRoom {
  id        String       @id @default(uuid())
  type      ChatRoomType
  title     String?
  createdBy String       @map("created_by")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  creator   User           @relation("ChatRoomCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members     ChatMember[]
  messages    ChatMessage[]
  attachments ChatMessageAttachment[]
  directKey   ChatDirectKey?

  @@index([updatedAt])
  @@map("chat_rooms")
}

model ChatDirectKey {
  userLowId  String @map("user_low_id")
  userHighId String @map("user_high_id")
  roomId     String @unique @map("room_id")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userLowId, userHighId])
  @@map("chat_direct_keys")
}

model ChatMember {
  roomId     String    @map("room_id")
  userId     String    @map("user_id")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
  @@map("chat_members")
}

model ChatMessage {
  id               String    @id @default(uuid())
  roomId           String    @map("room_id")
  authorId         String    @map("author_id")
  body             String
  replyToMessageId String?   @map("reply_to_message_id")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")
  editedAt         DateTime? @map("edited_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  room        ChatRoom                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author      User                    @relation("ChatMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  deletedBy   User?                   @relation("ChatMessageDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  replyTo     ChatMessage?            @relation("ChatMessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies     ChatMessage[]           @relation("ChatMessageReply")
  deliveries  ChatMessageDelivery[]
  reactions   ChatMessageReaction[]
  attachments ChatMessageAttachment[]
  hides       ChatMessageUserHide[]

  @@index([roomId, createdAt])
  @@index([replyToMessageId])
  @@map("chat_messages")
}

model ChatMessageUserHide {
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  hiddenAt  DateTime @default(now()) @map("hidden_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId, messageId])
  @@map("chat_message_user_hides")
}

model ChatMessageAttachment {
  id         String   @id @default(uuid())
  roomId     String   @map("room_id")
  uploaderId String   @map("uploader_id")
  messageId  String?  @map("message_id")
  fileName   String   @map("file_name")
  mimeType   String   @map("mime_type")
  size       Int
  width      Int?
  height     Int?
  url        String
  createdAt  DateTime @default(now()) @map("created_at")

  room     ChatRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  uploader User         @relation("ChatAttachmentUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  message  ChatMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([roomId, uploaderId, messageId])
  @@index([messageId, createdAt])
  @@map("chat_message_attachments")
}

model ChatMessageReaction {
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([messageId])
  @@map("chat_message_reactions")
}

model ChatMessageDelivery {
  messageId   String   @map("message_id")
  userId      String   @map("user_id")
  deliveredAt DateTime @default(now()) @map("delivered_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId, deliveredAt])
  @@map("chat_message_deliveries")
}
